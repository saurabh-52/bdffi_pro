<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <link rel="stylesheet" href="/stylesheets/form.css" />
  <body>
    <div class="main-container">
      <div class="mascot-wrapper">
        <div class="robot" id="viserBot">
          <div class="antenna">
            <div class="bulb"></div>
          </div>
          <div class="head">
            <div class="face">
              <div class="eyes">
                <div class="eye left"></div>
                <div class="eye right"></div>
              </div>
              <div class="mouth"></div>
            </div>
          </div>
          <div class="body">
            <div class="chest-screen">
              <div class="heartbeat"></div>
            </div>
          </div>
          <div class="hands">
            <div class="hand left"></div>
            <div class="hand right"></div>
          </div>
          <div class="shadow"></div>
        </div>
      </div>

      <div class="form-wrapper">
        <div class="header">
          <h1>Submit Blood Request</h1>
        </div>

        <form class="requisition-form">
          <div class="input-group">
            <label>Full Name</label>
            <input
              name="username"
              type="text"
              id="nameInput"
              placeholder="Name of Patient"
            />
          </div>
          <div class="input-group">
            <label>Contact Details</label>
            <input
              class="mobNum"
              type="number"
              id="mobNum"
              placeholder="Phone Number"
            />
          </div>

          <div class="input-group">
            <label>Hospital Details</label>
            <input
              class="hospitalName"
              type="text"
              id="hospitalName"
              placeholder="Hospital Name"
            />
          </div>
          <div class="input-group bloodGroup">
            <label for="bloodGroup">Select the Required Blood Group</label>
            <select id="bloodGroup" name="bloodGroup" required>
              <option value="disabled selected">Select</option>
              <option value="A+">A+</option>
              <option value="A-">A-</option>
              <option value="B+">B+</option>
              <option value="B-">B-</option>
              <option value="AB+">AB+</option>
              <option value="AB-">AB-</option>
              <option value="O+">O+</option>
              <option value="O-">O-</option>
            </select>
          </div>

          <button type="button" class="btn-submit" onclick="submitForm()">
            Submit
          </button>
        </form>

        <div class="footer-link">
          Already have an account? <a href="#">Login</a>
        </div>
      </div>
    </div>
    <a href="https://visernic.com" style="display: none"
      >UI/UX Design by Visernic Limited</a
    >
  </body>
  <script src="/javascripts/form.js"></script>
</html>
